# ==============================
# Kategoryzator - runtime config
# ==============================

# --- API / core ---
SKIP_REGISTRY_VALIDATION=0
PREDICT_LOG_PATH=logs/predictions.jsonl
BOOKED_DB_PATH=logs/booked_invoices.db
BOOKED_SIMILARITY_THRESHOLD=0.92

# --- Company confidence defaults ---
DEFAULT_CONFIDENCE_EXACT=0.92
DEFAULT_CONFIDENCE_AI=0.75
DEFAULT_COMPANY_LLM_ENABLED=0
COMPANY_CONFIG_CACHE_TTL_SECONDS=300
BOOKED_EMBEDDING_DIM=128

# --- AWS / SQS consumer ---
AWS_REGION=eu-central-1
SQS_QUEUE_URL=
SQS_POLL_INTERVAL_SECONDS=3600
SQS_MAX_MESSAGES_PER_BATCH=10
SQS_VISIBILITY_TIMEOUT=60

# --- AWS Bedrock LLM fallback ---
LLM_FALLBACK_ENABLED=0
LLM_AWS_REGION=eu-central-1
LLM_BEDROCK_MODEL_ID=
LLM_MAX_TOKENS=800
LLM_TEMPERATURE=0.1
LLM_TIMEOUT_SECONDS=20

# Prefer IAM Role in AWS (ECS Task Role / EC2 Instance Profile).
# Uncomment only for local tests.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=